<?php

use Illuminate\Foundation\Testing\RefreshDatabase;
use Modularity\Support\Facades\Module;
use Modularity\Testing\InteractsWithModules;
use Modules\{{PascalName}}\Models\{{PascalName}};

// {{PascalName}} module — starter feature test.
//
// Generated by `php artisan module:make-module`. It proves the two things the
// package guarantees for any module: lifecycle (install + activate) and per-tenant
// data isolation. Extend it with your module's own behavior.
//
// Assumes Pest + your app's default `Tests\TestCase`. Using PHPUnit classes? Make a
// class that extends Tests\TestCase and `use`s the InteractsWithModules trait instead.
//
// For the test runner to find this file, register a "Modules" testsuite in phpunit.xml
// pointing a <directory> at Modules/*/tests.

uses(Tests\TestCase::class, RefreshDatabase::class, InteractsWithModules::class);

beforeEach(function () {
    // installAndActivateModule() installs the module (running its migrations and
    // registering its permissions), re-boots the loader so its routes/views/nav
    // register, and activates it for tenant #1 — no loader internals required.
    $this->installAndActivateModule('{{kebab-slug}}', tenantId: 1);
});

it('scopes {{kebab-slug}} records to the current tenant', function () {
    // A record created under tenant 1 is invisible to tenant 2, and vice-versa.
    $this->asTenant(1, fn () => {{PascalName}}::create([]));

    $this->asTenant(2, fn () => expect({{PascalName}}::count())->toBe(0));
    $this->asTenant(1, fn () => expect({{PascalName}}::count())->toBe(1));
});

it('is active only for tenants that activated it', function () {
    expect(Module::activeFor('{{kebab-slug}}', 1))->toBeTrue();
    expect(Module::activeFor('{{kebab-slug}}', 2))->toBeFalse();
});

/*
|--------------------------------------------------------------------------
| HTTP & permission gating (needs your app's auth + tenant wiring)
|--------------------------------------------------------------------------
| A module's routes are gated by `module.active:{{kebab-slug}}` and, optionally,
| `can:` permissions. Testing them needs an authenticated user whose tenant is set
| on the request. With the wiring described in Modularity's INTEGRATION.md
| (a SetCurrentTenant middleware + a Gate::before permission grant) it looks like:
|
| it('lets an authorized user reach the module', function () {
|     $user = \App\Models\User::factory()->create([
|         'tenant_id'   => 1,
|         'permissions' => ['{{kebab-slug}}.view'],
|     ]);
|
|     $this->actingAs($user)
|         ->get(route('{{kebab-slug}}.index'))
|         ->assertOk();
| });
|
| it('404s a tenant that has not activated the module', function () {
|     $user = \App\Models\User::factory()->create(['tenant_id' => 2]);
|
|     $this->actingAs($user)
|         ->get(route('{{kebab-slug}}.index'))
|         ->assertNotFound();
| });
*/
